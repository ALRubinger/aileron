# Local development defaults. Copy to .env or let `task up` do it for you.
# Do NOT use these values in production.
AILERON_JWT_SIGNING_KEY=local-dev-signing-key-not-for-production
AILERON_AUTO_VERIFY_EMAIL=true

# OAuth providers (optional — enable by setting client ID and secret)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Stable OAuth callback domain (optional — for Railway branch deployments).
# Set AILERON_OAUTH_CALLBACK_BASE_URL to a stable domain so OAuth providers
# only need one registered redirect URI. Set AILERON_TRUSTED_ORIGINS to a
# comma-separated list of allowed relay targets (supports "*.subdomain" wildcards).
# See docs/adr/0006-stable-oauth-callback-domain.md for the full design.
# AILERON_OAUTH_CALLBACK_BASE_URL=https://auth.withaileron.ai
# AILERON_TRUSTED_ORIGINS=*.up.railway.app,withaileron.ai
