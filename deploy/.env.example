# Local development defaults. Copy to .env or let `task up` do it for you.
# Do NOT use these values in production.
AILERON_JWT_SIGNING_KEY=local-dev-signing-key-not-for-production
AILERON_AUTO_VERIFY_EMAIL=true

# OAuth providers (optional — enable by setting client ID and secret)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
